#!/usr/bin/env bash
set -euo pipefail

# Controls the launchd-managed autossh tunnel from this Mac to the
# Spark's Ollama port. The actual ssh/autossh process is started by
# launchd from ~/Library/LaunchAgents/com.local-hub.tunnel.plist, which
# is installed by scripts/10-litellm.sh.
#
# Subcommands:
#   up      -- kickstart the launchd job (start if stopped)
#   down    -- stop the job (without unloading)
#   status  -- show launchd state + whether the local port is bound

LABEL=com.local-hub.tunnel
DOMAIN="gui/$(id -u)"
LOCAL_PORT=11435

cmd="${1:-status}"

ensure_loaded() {
  if ! launchctl print "$DOMAIN/$LABEL" >/dev/null 2>&1; then
    echo "tunnel launchd job not installed. Run scripts/10-litellm.sh first." >&2
    exit 1
  fi
}

case "$cmd" in
  up)
    ensure_loaded
    launchctl kickstart -k "$DOMAIN/$LABEL"
    echo "tunnel kicked: $DOMAIN/$LABEL"
    ;;
  down)
    ensure_loaded
    launchctl stop "$DOMAIN/$LABEL"
    echo "tunnel stop signaled (launchd will not restart it until: hub-tunnel up)"
    ;;
  status)
    ensure_loaded
    state="$(launchctl print "$DOMAIN/$LABEL" 2>/dev/null | awk -F'= ' '/^[[:space:]]+state/ {print $2; exit}')"
    pid="$(launchctl print "$DOMAIN/$LABEL"  2>/dev/null | awk -F'= ' '/^[[:space:]]+pid/   {print $2; exit}')"
    bound="no"
    if lsof -nP -iTCP:${LOCAL_PORT} -sTCP:LISTEN >/dev/null 2>&1; then bound="yes"; fi
    printf 'state=%s pid=%s port_%s_bound=%s\n' "${state:-?}" "${pid:-?}" "$LOCAL_PORT" "$bound"
    [[ "$bound" == "yes" ]] || exit 1
    ;;
  *)
    echo "usage: $(basename "$0") {up|down|status}" >&2
    exit 2
    ;;
esac
