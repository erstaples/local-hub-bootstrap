<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.local-hub.litellm</string>

  <!-- Wrap in /bin/sh so we can source the env file (master key etc.)
       before exec'ing the proxy. launchd doesn't run a shell on its own. -->
  <key>ProgramArguments</key>
  <array>
    <string>/bin/sh</string>
    <string>-c</string>
    <string>. "__ENV_FILE__" &amp;&amp; exec "__PIPX_BIN__/litellm" --config "__CONFIG_FILE__" --host 127.0.0.1 --port 4000</string>
  </array>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>__PIPX_BIN__:__HOMEBREW_PREFIX__/bin:/usr/bin:/bin</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
  </dict>
  <key>ThrottleInterval</key>
  <integer>10</integer>

  <key>StandardOutPath</key>
  <string>__LOG_DIR__/litellm.log</string>
  <key>StandardErrorPath</key>
  <string>__LOG_DIR__/litellm.log</string>
</dict>
</plist>
